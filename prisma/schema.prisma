model Territory {
  id             String          @id @default(uuid())
  name           String // e.g. "Tokyo", "New York", "London"
  countryCode    String // ISO 3166-1 alpha-2, e.g. "JP", "US", "GB"
  countryName    String // e.g. "Japan", "United States"
  adminLevel     Int             @default(0) // 0 = country, 1 = state/province, 2 = district
  tier           Int             @default(1) // 1=Outpost, 2=Town, 3=City, 4=Major City, 5=Metropolis
  isIsland       Boolean         @default(false)
  latitude       Float
  longitude      Float
  polygonId      String? // Reference to GeoJSON feature ID for highlighting
  ownerId        String? // Current owner (student who conquered it)
  owner          User?           @relation("TerritoryOwner", fields: [ownerId], references: [id])
  castle         Castle?
  pendingAttacks PendingAttack[]
  conqueredAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([countryCode])
  @@index([ownerId])
  @@index([tier])
  @@map("territories")
}

model Castle {
  id                 String    @id @default(uuid())
  territoryId        String    @unique
  territory          Territory @relation(fields: [territoryId], references: [id])
  ownerId            String
  owner              User      @relation("CastleOwner", fields: [ownerId], references: [id])
  level              Int       @default(1) // 1-10
  name               String? // Custom name by player, e.g. "Fort Vibhor"
  defensePoints      Int       @default(100)
  attackPoints       Int       @default(50)
  coinsInvested      Int       @default(0) // AlcoCoins spent on upgrades
  garrisonDragons    Json? // [{dragonId, dragonType, power}]
  totalDragonPower   Int       @default(0) // Sum of garrisoned dragon powers
  upgradeStartedAt   DateTime? @map("upgrade_started_at")
  upgradeCompletesAt DateTime? @map("upgrade_completes_at")
  upgradingToLevel   Int?      @map("upgrading_to_level")
  shieldExpiresAt    DateTime? @map("shield_expires_at")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ownerId])
  @@map("castles")
}

model PendingAttack {
  id               String   @id @default(uuid())
  type             String   @default("ATTACK") @map("type") // "ATTACK" or "CONQUEST"
  attackerId       String   @map("attacker_id")
  territoryId      String   @map("territory_id")
  dragonIds        Json     @map("dragon_ids") // string[] of UserDragon ids
  totalAttackPower Int      @map("total_attack_power")
  coinsCost        Int      @map("coins_cost")
  castleName       String?  @map("castle_name") // Only for CONQUEST type
  startedAt        DateTime @default(now()) @map("started_at")
  completesAt      DateTime @map("completes_at")
  resolved         Boolean  @default(false)
  success          Boolean?

  attacker  User      @relation("PendingAttacks", fields: [attackerId], references: [id])
  territory Territory @relation(fields: [territoryId], references: [id])

  @@index([attackerId])
  @@index([territoryId])
  @@map("pending_attacks")
}

model ConquestLog {
  id           String   @id @default(uuid())
  territoryId  String
  attackerId   String // Who attacked
  defenderId   String? // Who defended (null if unclaimed)
  attackerName String
  defenderName String?
  success      Boolean
  coinsSpent   Int      @default(0)
  coinsWon     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([attackerId])
  @@index([territoryId])
  @@map("conquest_logs")
}

