  totalFocusScore   Float    @map("total_focus_score")
  sessionCount      Int      @map("session_count")
  totalMinutes      Float    @map("total_minutes")
  avgWalkMultiplier Float?   @map("avg_walk_multiplier")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@map("daily_focus_scores")
}

model ManualWalkLog {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  date      DateTime @db.Date
  loggedAt  DateTime @default(now()) @map("logged_at")
  user      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@map("manual_walk_logs")
}

// ============================================================================
// ADVISOR DASHBOARD SYSTEM
// ============================================================================

model SessionNote {
  id                       String              @id @default(uuid())
  sessionId                String              @unique @map("session_id")
  focusArea                String              @map("focus_area") // Academic, Career, Personal
  subAreas                 String[]            @map("sub_areas")
  additionalParticipants   String[]            @map("additional_participants")
  attendance               String // Present, Absent, Late
  blueprintAdherence       Boolean             @default(true) @map("blueprint_adherence")
  agenda                   String?
  notes                    String?
  externalIntervention     String?             @map("external_intervention") // null = no, string = reason
  psychologistIntervention String?             @map("psychologist_intervention") // null = no, string = reason
  transcriptUrl            String?             @map("transcript_url")
  aiSummaryUrl             String?             @map("ai_summary_url")
  gammaDeckUrl             String?             @map("gamma_deck_url")
  aiSummary                String?             @map("ai_summary")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")
  session                  Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionItems              SessionActionItem[]

  @@map("session_notes")
}

model SessionActionItem {
  id            String      @id @default(uuid())
  sessionNoteId String      @map("session_note_id")
  assignedTo    String      @map("assigned_to") // 'student' | 'advisor'
  title         String
  description   String?
  dueDate       DateTime?   @map("due_date")
  status        String      @default("pending") // pending, in_progress, done
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  sessionNote   SessionNote @relation(fields: [sessionNoteId], references: [id], onDelete: Cascade)
  todoItem      TodoItem?

  @@index([sessionNoteId])
  @@map("session_action_items")
}

model TodoItem {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  studentId   String?            @map("student_id") // which student this relates to
  title       String
  description String?
  source      String // 'ai_summary' | 'session_action' | 'manual' | 'auto_calendar'
  sourceId    String?            @unique @map("source_id") // FK to SessionActionItem
  dueDate     DateTime?          @map("due_date")
  status      String             @default("pending") // pending, in_progress, done
  priority    String             @default("normal") // low, normal, high
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionItem  SessionActionItem? @relation(fields: [sourceId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("todo_items")
}

model ChatConversation {
  id           String            @id @default(uuid())
  name         String? // null for DMs, name for groups
  isGroup      Boolean           @default(false) @map("is_group")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_conversations")
}

model ChatParticipant {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  userId         String           @map("user_id")
  lastReadAt     DateTime?        @map("last_read_at")
  joinedAt       DateTime         @default(now()) @map("joined_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  senderId       String           @map("sender_id")
  content        String
  messageType    String           @default("text") // text, system, booking_link
  metadata       Json? // { sessionId, meetLink } for booking messages
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("ChatMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model StudentAdvisorNote {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  advisorId String   @map("advisor_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  student   User     @relation("StudentNotesReceived", fields: [studentId], references: [id], onDelete: Cascade)
  advisor   User     @relation("AdvisorNotesWritten", fields: [advisorId], references: [id], onDelete: Cascade)

  @@unique([studentId, advisorId])
  @@map("student_advisor_notes")
}

model RoadmapItem {
  id          String        @id @default(uuid())
  studentId   String        @map("student_id")
  advisorId   String        @map("advisor_id")
  scope       String // 'annual' | 'quarterly' | 'monthly'
  category    String // 'Academic' | 'Career' | 'Personal'
  title       String
  description String?
  parentId    String?       @map("parent_id")
  sortOrder   Int           @default(0) @map("sort_order")
  year        Int?
  quarter     String? // Q1, Q2, Q3, Q4
  month       String?
  status      String        @default("upcoming") // done, in-progress, upcoming
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  student     User          @relation("StudentRoadmapItems", fields: [studentId], references: [id], onDelete: Cascade)
  parent      RoadmapItem?  @relation("RoadmapHierarchy", fields: [parentId], references: [id])
  children    RoadmapItem[] @relation("RoadmapHierarchy")
  tasks       RoadmapTask[]

  @@index([studentId])
  @@index([parentId])
  @@map("roadmap_items")
}

model RoadmapTask {
  id            String      @id @default(uuid())
  roadmapItemId String      @map("roadmap_item_id")
  title         String
  status        String      @default("pending") // pending, done
  dueDate       DateTime?   @map("due_date")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  roadmapItem   RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)

  @@index([roadmapItemId])
  @@map("roadmap_tasks")
}

model SessionFeedback {
  id                  String   @id @default(uuid())
  sessionId           String   @map("session_id")
  userId              String   @map("user_id")
  engagementRating    Int      @map("engagement_rating") // 1-5 stars
  progressRating      Int      @map("progress_rating") // 1-5 stars
  preparednessRating  Int      @map("preparedness_rating") // 1-5 stars
  comment             String?
  createdAt           DateTime @default(now()) @map("created_at")
  session             Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                User     @relation("SessionFeedbackGiven", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("session_feedback")
}
