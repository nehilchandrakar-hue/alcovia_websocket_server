generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                     @id @default(uuid())
  name                    String
  email                   String                     @unique
  role                    UserRole
  programStartDate        DateTime                   @map("program_start_date")
  board                   String
  passwordHash            String                     @map("password_hash")
  advisorId               String?                    @map("advisor_id")
  careerCounselorId       String?                    @map("career_counselor_id")
  parentId                String?                    @map("parent_id")
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  grade                   Int?
  expoPushToken           String?                    @map("expo_push_token")
  activeDragonType        String?                    @map("active_dragon_type")
  baseLatitude            Float?                     @map("base_latitude")
  baseLongitude           Float?                     @map("base_longitude")
  academicYears           AcademicYear[]
  activePowerUsages       ActivePowerUsage[]
  alcoCoinTransactions    AlcoCoinTransaction[]
  alcoCoin                AlcoCoin?
  burnoutAssessments      BurnoutAssessment[]
  dailyFocusScores        DailyFocusScore[]
  dailyStudyStatistics    DailyStudyStatistics[]
  dailyWellnessSnapshots  DailyWellnessSnapshot[]
  examWeekSnoozes         ExamWeekSnooze[]
  exams                   Exam[]
  focusSessions           FocusSession[]
  gmailIntegration        GmailIntegration?
  googleCalendar          GoogleCalendarIntegration?
  manualWalkLogs          ManualWalkLog[]
  hourlyStrainSnapshots   HourlyStrainSnapshot[]
  litmusTest              LitmusTest?
  monthlyMegaLeague       MonthlyMegaLeague[]
  passwordResetTokens     PasswordResetToken[]
  quarterlyGoals          QuarterlyGoal[]
  rankingProfile          RankingProfile?
  rescheduleRequests      RescheduleRequest[]
  sessionParticipants     SessionParticipant[]
  createdSessions         Session[]
  socialFeedEvents        SocialFeedEvent[]
  socialFeedMute          SocialFeedMute?
  socialFeedReactions     SocialFeedReaction[]
  streakFreezes           StreakFreeze[]
  subjectExamPerformance  SubjectExamPerformance[]
  subjectYearSummary      SubjectYearSummary[]
  subjects                Subject[]
  userDragons             UserDragon[]
  pendingAttacks          PendingAttack[]            @relation("PendingAttacks")
  advisor                 User?                      @relation("AdvisorStudents", fields: [advisorId], references: [id])
  advisorStudents         User[]                     @relation("AdvisorStudents")
  careerCounselor         User?                      @relation("CounselorStudents", fields: [careerCounselorId], references: [id])
  careerCounselorStudents User[]                     @relation("CounselorStudents")
  parent                  User?                      @relation("ParentChildren", fields: [parentId], references: [id])
  children                User[]                     @relation("ParentChildren")
  weeklyWellnessScores    WeeklyWellnessScore[]
  weeklyWellnessWinners   WeeklyWellnessWinner[]
  wellnessBadges          WellnessBadge[]
  rivalOf                 WellnessRival[]            @relation("RivalOf")
  studentRivals           WellnessRival[]            @relation("StudentRival")
  wellnessStreaks         WellnessStreak[]
  whoopIntegration        WhoopIntegration?
  whoopWorkouts           WhoopWorkout[]
  yearlyPerformance       YearOverallPerformance[]
  deviationRecords        DeviationRecord[]
  ownedTerritories        Territory[]                @relation("TerritoryOwner")
  ownedCastles            Castle[]                   @relation("CastleOwner")
  todoItems               TodoItem[]
  chatParticipants        ChatParticipant[]
  chatMessagesSent        ChatMessage[]              @relation("ChatMessagesSent")
  studentNotesReceived    StudentAdvisorNote[]       @relation("StudentNotesReceived")
  advisorNotesWritten     StudentAdvisorNote[]       @relation("AdvisorNotesWritten")
  studentRoadmapItems     RoadmapItem[]              @relation("StudentRoadmapItems")
  sessionFeedbackGiven    SessionFeedback[]          @relation("SessionFeedbackGiven")

  @@index([advisorId])
  @@index([careerCounselorId])
  @@index([email])
  @@map("users")
}

model GoogleCalendarIntegration {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiryDate   BigInt?  @map("expiry_date")
  idToken      String?  @map("id_token")
  scope        String?
  tokenType    String?  @map("token_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_integrations")
}

model GmailIntegration {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiryDate   BigInt?  @map("expiry_date")
  idToken      String?  @map("id_token")
  scope        String?
  tokenType    String?  @map("token_type")
  emailAddress String?  @map("email_address")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_integrations")
}

model AcademicYear {
  id                     String                   @id @default(uuid())
  studentId              String                   @map("student_id")
  label                  String
  startDate              DateTime                 @map("start_date")
  endDate                DateTime                 @map("end_date")
  student                User                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exams                  Exam[]
  quarters               Quarter[]
  sessions               Session[]
  subjectExamPerformance SubjectExamPerformance[]
  subjectYearSummaries   SubjectYearSummary[]
  subjects               Subject[]
  yearlyPerformance      YearOverallPerformance[]

  @@unique([studentId, label])
  @@index([studentId])
  @@map("academic_years")
}

model Quarter {
  id             String          @id @default(uuid())
  name           String
  academicYearId String          @map("academic_year_id")
  isActive       Boolean         @default(false) @map("is_active")
  chapters       Chapter[]
  quarterlyGoals QuarterlyGoal[]
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sessions       Session[]

  @@unique([academicYearId, name])
  @@index([academicYearId])
  @@map("quarters")
}

model Session {
  id                 String               @id @default(uuid())
  name               String
  sessionType        SessionType          @map("session_type")
  sessionDate        DateTime             @map("session_date")
  startTime          DateTime             @map("start_time")
  endTime            DateTime             @map("end_time")
  isCommon           Boolean              @default(false) @map("is_common")
  isFlexible         Boolean              @default(true) @map("is_flexible")
  createdById        String?              @map("created_by_id")
  academicYearId     String               @map("academic_year_id")
  quarterId          String               @map("quarter_id")
  rescheduleRequests RescheduleRequest[]
  participants       SessionParticipant[]
  quiz               Quiz?
  academicYear       AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  createdBy          User?                @relation(fields: [createdById], references: [id])
  quarter            Quarter              @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  sessionNote        SessionNote?
  feedback           SessionFeedback[]

  @@index([createdById])
  @@index([academicYearId])
  @@index([quarterId])
  @@index([sessionDate])
  @@map("sessions")
}

model SessionParticipant {
  id                    String                @id @default(uuid())
  sessionId             String                @map("session_id")
  userId                String                @map("user_id")
  status                AttendanceStatus
  markedAt              DateTime              @default(now()) @map("marked_at")
  googleEventId         String?               @map("google_event_id")
  studentAcknowledgment StudentAcknowledgment @default(Pending) @map("student_acknowledgment")
  session               Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("session_participants")
}

model RescheduleRequest {
  id                String   @id @default(uuid())
  sessionId         String   @map("session_id")
  userId            String   @map("user_id")
  currentStartTime  DateTime @map("current_start_time")
  currentEndTime    DateTime @map("current_end_time")
  proposedStartTime DateTime @map("proposed_start_time")
  proposedEndTime   DateTime @map("proposed_end_time")
  status            String   @default("PENDING")
  reason            String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reschedule_requests")
}

model GoalCategory {
  id    String           @id @default(uuid())
  type  GoalCategoryType @unique
  goals QuarterlyGoal[]

  @@map("goal_categories")
}

model QuarterlyGoal {
  id           String        @id @default(uuid())
  studentId    String        @map("student_id")
  quarterId    String        @map("quarter_id")
  categoryId   String        @map("category_id")
  description  String
  status       GoalStatus    @default(NotStarted)
  progressPct  Float         @default(0) @map("progress_pct")
  monthlyGoals MonthlyGoal[]
  category     GoalCategory  @relation(fields: [categoryId], references: [id])
  quarter      Quarter       @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  student      User          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([quarterId])
  @@index([categoryId])
  @@map("quarterly_goals")
}

model MonthlyGoal {
  id              String        @id @default(uuid())
  quarterlyGoalId String        @map("quarterly_goal_id")
  monthName       String        @map("month_name")
  description     String?
  status          GoalStatus    @default(NotStarted)
  progressPct     Float         @default(0) @map("progress_pct")
  remarks         String?
  quarterlyGoal   QuarterlyGoal @relation(fields: [quarterlyGoalId], references: [id], onDelete: Cascade)

  @@unique([quarterlyGoalId, monthName])
  @@map("monthly_goals")
}

model Subject {
  id                     String                   @id @default(uuid())
  studentId              String                   @map("student_id")
  academicYearId         String                   @map("academic_year_id")
  name                   String
  chapters               Chapter[]
  exams                  Exam[]
  subjectExamPerformance SubjectExamPerformance[]
  subjectYearSummaries   SubjectYearSummary[]
  academicYear           AcademicYear             @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student                User                     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, name])
  @@index([studentId])
  @@index([academicYearId])
  @@map("subjects")
}

model Chapter {
  id             String              @id @default(uuid())
  subjectId      String              @map("subject_id")
  quarterId      String              @map("quarter_id")
  name           String
  isComingInExam Boolean             @default(false) @map("is_coming_in_exam")
  chapterExam    ChapterExam[]
  progress       ChapterProgress?
  revisions      ChapterRevision[]
  scores         ChapterScore[]
  tasks          ChapterTask[]
  timeSummary    ChapterTimeSummary?
  quarter        Quarter             @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  subject        Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, quarterId, name])
  @@index([subjectId])
  @@index([quarterId])
  @@map("chapters")
}

model ChapterTask {
  id                 String         @id @default(uuid())
  chapterId          String         @map("chapter_id")
  taskType           String         @map("task_type") @db.VarChar(50)
  taskStatus         TaskStatus     @default(NotStarted) @map("task_status")
  estimatedTimeHours Decimal?       @map("estimated_time_hours") @db.Decimal(5, 2)
  actualTimeHours    Decimal?       @map("actual_time_hours") @db.Decimal(5, 2)
  timeDeviationHours Decimal?       @map("time_deviation_hours") @db.Decimal(5, 2)
  completedAt        DateTime?      @map("completed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at")
  chapter            Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  focusSessions      FocusSession[]

  @@index([chapterId])
  @@index([taskStatus])
  @@map("chapter_tasks")
}

model ChapterRevision {
  id                 String         @id @default(uuid())
  chapterId          String         @map("chapter_id")
  revisionType       String         @map("revision_type") @db.VarChar(50)
  revisionStatus     RevisionStatus @default(NotStarted) @map("revision_status")
  estimatedTimeHours Decimal?       @map("estimated_time_hours") @db.Decimal(5, 2)
  actualTimeHours    Decimal?       @map("actual_time_hours") @db.Decimal(5, 2)
  attemptNo          Int            @map("attempt_no")
  timeDeviationHours Decimal?       @map("time_deviation_hours") @db.Decimal(5, 2)
  completedAt        DateTime?      @map("completed_at")
  chapter            Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, revisionType, attemptNo])
  @@index([chapterId])
  @@index([revisionStatus])
  @@map("chapter_revisions")
}

model Exam {
  id                     String                   @id @default(uuid())
  studentId              String                   @map("student_id")
  name                   examType
  subjectId              String?                  @map("subject_id")
  academicYearId         String?                  @map("academic_year_id")
  conductedAt            DateTime                 @default(now()) @map("conducted_at")
  chapterExams           ChapterExam[]
  academicYear           AcademicYear?            @relation(fields: [academicYearId], references: [id])
  student                User                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject                Subject?                 @relation(fields: [subjectId], references: [id])
  subjectExamPerformance SubjectExamPerformance[]

  @@index([studentId])
  @@index([subjectId])
  @@index([academicYearId])
  @@index([conductedAt])
  @@map("exams")
}

model ChapterExam {
  id        String  @id @default(uuid())
  chapterId String  @map("chapter_id")
  examId    String  @map("exam_id")
  isComing  Boolean @default(false) @map("is_coming")
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([chapterId, examId])
  @@index([examId])
  @@map("chapter_exams")
}

model ChapterScore {
  id                 String    @id @default(uuid())
  chapterId          String    @map("chapter_id")
  scoreType          ScoreType @map("score_type")
  name               String
  marksObtained      Decimal   @map("marks_obtained") @db.Decimal(5, 2)
  maxMarks           Decimal   @map("max_marks") @db.Decimal(5, 2)
  accuracyPercentage Decimal   @map("accuracy_percentage") @db.Decimal(5, 2)
  attemptNo          Int       @map("attempt_no")
  recordedOn         DateTime  @default(now()) @map("recorded_on") @db.Date
  chapter            Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, scoreType, attemptNo])
  @@index([chapterId])
  @@index([scoreType])
  @@map("chapter_scores")
}

model ChapterProgress {
  id            String  @id @default(uuid())
  chapterId     String  @unique @map("chapter_id")
  completionPct Float   @default(0) @map("completion_pct")
  revisionPct   Float   @default(0) @map("revision_pct")
  overallStatus String  @map("overall_status")
  chapter       Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("chapter_progress")
}

model ChapterTimeSummary {
  id                       String  @id @default(uuid())
  chapterId                String  @unique @map("chapter_id")
  estCompletionHours       Decimal @default(0) @map("est_completion_hours") @db.Decimal(5, 2)
  actualCompletionHours    Decimal @default(0) @map("actual_completion_hours") @db.Decimal(5, 2)
  completionDeviationHours Decimal @default(0) @map("completion_deviation_hours") @db.Decimal(5, 2)
  estRevisionHours         Decimal @default(0) @map("est_revision_hours") @db.Decimal(5, 2)
  actualRevisionHours      Decimal @default(0) @map("actual_revision_hours") @db.Decimal(5, 2)
  revisionDeviationHours   Decimal @default(0) @map("revision_deviation_hours") @db.Decimal(5, 2)
  chapter                  Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("chapter_time_summaries")
}

model SubjectExamPerformance {
  id               String       @id @default(uuid())
  studentId        String       @map("student_id")
  subjectId        String       @map("subject_id")
  academicYearId   String       @map("academic_year_id")
  examId           String       @map("exam_id")
  totalMarks       Float        @map("total_marks")
  marksObtained    Float        @map("marks_obtained")
  percentage       Float
  grade            String
  percentilePUM    Float        @map("percentile_pum")
  targetPUM        Float        @map("target_pum")
  targetRawScore   Float        @map("target_raw_score")
  targetPercentage Float        @map("target_percentage")
  improvementPct   Float        @map("improvement_pct")
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exam             Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  student          User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, examId])
  @@index([studentId, academicYearId])
  @@index([subjectId])
  @@index([examId])
  @@map("subject_exam_performances")
}

model SubjectYearSummary {
  id                      String       @id @default(uuid())
  studentId               String       @map("student_id")
  subjectId               String       @map("subject_id")
  academicYearId          String       @map("academic_year_id")
  term1Score              Float        @map("term1_score")
  term1Percentage         Float        @map("term1_percentage")
  midSemScore             Float        @map("mid_sem_score")
  midSemPercentage        Float        @map("mid_sem_percentage")
  term2Score              Float        @map("term2_score")
  term2Percentage         Float        @map("term2_percentage")
  endSemScore             Float        @map("end_sem_score")
  endSemPercentage        Float        @map("end_sem_percentage")
  overallPct              Float        @map("overall_pct")
  overallGrade            String       @map("overall_grade")
  percentilePUM           Float        @map("percentile_pum")
  improvementFromPrevYear Float        @map("improvement_from_prev_year")
  academicYear            AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student                 User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject                 Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYearId])
  @@index([studentId, academicYearId])
  @@map("subject_year_summaries")
}

model YearOverallPerformance {
  id             String       @id @default(uuid())
  studentId      String       @map("student_id")
  academicYearId String       @map("academic_year_id")
  overallPct     Float        @map("overall_pct")
  improvementPct Float?       @map("improvement_pct")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@index([studentId])
  @@map("year_overall_performances")
}

model LitmusTest {
  id             String          @id @default(uuid())
  studentId      String          @unique @map("student_id")
  verbalScore    Float           @map("verbal_score")
  quantScore     Float           @map("quant_score")
  logicalScore   Float           @map("logical_score")
  ecaScore       Float           @default(0) @map("eca_score")
  totalScore     Float           @map("total_score")
  conductedAt    DateTime        @default(now()) @map("conducted_at")
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rankingProfile RankingProfile?

  @@map("litmus_tests")
}

model RankingProfile {
  id                    String           @id @default(uuid())
  studentId             String           @unique @map("student_id")
  litmusTestId          String           @unique @map("litmus_test_id")
  baselineRank          Int              @map("baseline_rank")
  currentRank           Int              @map("current_rank")
  previousRank          Int?             @map("previous_rank")
  guaranteedTier        String?          @map("guaranteed_tier")
  totalPenaltyPoints    Int              @default(0) @map("total_penalty_points")
  missedAttendanceCount Int              @default(0) @map("missed_attendance_count")
  lowVelocityDays       Int              @default(0) @map("low_velocity_days")
  mappedSatScore        Int?             @map("mapped_sat_score")
  lastCalculatedAt      DateTime         @default(now()) @map("last_calculated_at")
  history               RankingHistory[]
  litmusTest            LitmusTest       @relation(fields: [litmusTestId], references: [id], onDelete: Cascade)
  student               User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("ranking_profiles")
}

model RankingHistory {
  id               String         @id @default(uuid())
  rankingProfileId String         @map("ranking_profile_id")
  rank             Int
  changeAmount     Int?           @map("change_amount")
  changeReason     String?        @map("change_reason")
  recordedAt       DateTime       @default(now()) @map("recorded_at")
  rankingProfile   RankingProfile @relation(fields: [rankingProfileId], references: [id], onDelete: Cascade)

  @@index([rankingProfileId])
  @@index([recordedAt])
  @@map("ranking_history")
}

model DailyStudyStatistics {
  id                 String   @id @default(uuid())
  studentId          String   @map("student_id")
  date               DateTime @db.Date
  targetVelocity     Float    @map("target_velocity")
  achievedVelocity   Float    @map("achieved_velocity")
  tasksCompleted     Int      @map("tasks_completed")
  revisionsCompleted Int      @map("revisions_completed")
  velocityScore      Float    @map("velocity_score")
  studyHours         Decimal  @default(0) @map("study_hours") @db.Decimal(5, 2)
  focusQuality       Int?     @map("focus_quality")
  createdAt          DateTime @default(now()) @map("created_at")
  student            User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  @@map("daily_study_statistics")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model FocusSession {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  taskId            String?            @map("task_id")
  startTime         DateTime           @default(now()) @map("start_time")
  endTime           DateTime?          @map("end_time")
  durationSeconds   Int?               @map("duration_seconds")
  status            FocusSessionStatus @default(Running)
  dragonPowerEarned Int                @default(0) @map("dragon_power_earned")
  focusQualityScore Float?             @map("focus_quality_score")
  focusScore        Float?             @map("focus_score")
  walkMultiplier    Float?             @map("walk_multiplier")
  tapCount          Int?               @map("tap_count")
  failReason        String?            @map("fail_reason")
  task              ChapterTask?       @relation(fields: [taskId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDragon        UserDragon?
  deviationRecords  DeviationRecord[]

  @@index([userId])
  @@index([taskId])
  @@map("focus_sessions")
}

model UserDragon {
  id                   String       @id @default(uuid())
  userId               String       @map("user_id")
  dragonType           String       @default("scout") @map("dragon_type")
  earnedAt             DateTime     @default(now()) @map("earned_at")
  fromSessionId        String       @unique @map("from_session_id")
  isActive             Boolean      @default(false) @map("is_active")
  earnSource           String?      @map("earn_source")
  activeUntil          DateTime?    @map("active_until")
  consumedAt           DateTime?    @map("consumed_at")
  garrisonedAtCastleId String?      @map("garrisoned_at_castle_id") // null = free, set = locked at castle
  inBattle             Boolean      @default(false) @map("in_battle") // true = participating in pending attack
  session              FocusSession @relation(fields: [fromSessionId], references: [id], onDelete: Cascade)
